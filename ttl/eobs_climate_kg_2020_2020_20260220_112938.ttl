sensor:tg_sensor a sosa:Sensor,
        ssn:System ;
    rdfs:label "E-OBS Thermometer Network"@en ;
    rdfs:comment "Virtual sensor representing the E-OBS ensemble mean network for mean temperature measurements"@en ;
